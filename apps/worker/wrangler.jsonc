{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inboxkit",
  "main": "./src/index.ts",
  "compatibility_date": "2025-07-09",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "inboxkit",
      // Replace after: wrangler d1 create inboxkit
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "./migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "STORAGE",
      "bucket_name": "inboxkit-emails"
    }
  ]
}
